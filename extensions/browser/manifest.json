{
  "manifest_version": 3,
  "name": "xlOS — Install agents from X",
  "version": "0.1.0",
  "description": "Right-click any v2.15 manifest YAML on X to install it with xlOS.",
  "author": "AgentMindCloud",
  "homepage_url": "https://github.com/AgentMindCloud/xlOS",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icons/icon-32.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "contextMenus",
    "scripting",
    "activeTab",
    "storage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": [
        "content/detect-yaml.js"
      ],
      "css": [
        "content/install-flow.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}
