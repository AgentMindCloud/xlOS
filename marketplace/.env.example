# --- GitHub ---
# Raises the anonymous 60 req/hr rate limit to 5000 req/hr. No scopes required.
# https://github.com/settings/tokens
GITHUB_TOKEN=

# --- Site ---
# Base URL for absolute metadata (OG images, canonical URLs).
NEXT_PUBLIC_SITE_URL=https://grokagents.dev

# --- Vercel KV (install-count store) ---
# Provision at Vercel dashboard → Storage → KV; copy the REST credentials here.
# When unset, the app falls back to an in-memory store (OK for local dev,
# lost on redeploy).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Analytics (Plausible) ---
# Set to your registered domain (e.g. grokagents.dev) to enable the script.
# Leave empty to disable analytics entirely.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Optional self-host. Defaults to https://plausible.io when omitted.
NEXT_PUBLIC_PLAUSIBLE_HOST=
